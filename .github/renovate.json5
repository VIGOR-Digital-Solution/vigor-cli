{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended",
    ":semanticCommits",
    ":dependencyDashboard",
    ":prHourlyLimit2",
    "group:recommended",
  ],
  timezone: "Asia/Kuala_Lumpur",
  schedule: ["before 7am on monday"],
  labels: ["dependencies"],
  rangeStrategy: "bump",

  packageRules: [
    // Go module updates — group all gomod under one PR per week.
    {
      matchManagers: ["gomod"],
      groupName: "go modules",
      automerge: false,
    },
    // Pin and bump GitHub Action SHAs.
    {
      matchManagers: ["github-actions"],
      groupName: "github-actions",
      pinDigests: true,
    },
    // Toolchain bumps (Go itself).
    {
      matchPackageNames: ["go", "golang"],
      groupName: "toolchain (go)",
    },
    // Major bumps always need human review.
    {
      matchUpdateTypes: ["major"],
      automerge: false,
      addLabels: ["major-update"],
    },
  ],

  vulnerabilityAlerts: {
    labels: ["security"],
    schedule: ["at any time"],
  },
}
